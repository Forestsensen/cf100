# Default: treat as text with LF line endings
* text=auto eol=lf
* text encoding=utf-8

# Binary files: do NOT treat as text (preserve exact bytes)
*.png binary
*.ico binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.mp4 binary
*.webm binary
*.mp3 binary
*.ogg binary
